# Required
BALE_BOT_TOKEN=
METIS_API_KEY=

# Database
SQLITE_DB_PATH=messages.db

# Commands
ENABLE_BOT_COMMANDS=true
ALLOWED_COMMAND_USER_ID=1412990760
AUTO_MEMORIZE_ENABLED=true
AUTO_MEMORIZE_THRESHOLD=300

# Command limits
SUMMARY_DEFAULT_HOURS=24
SUMMARY_MIN_HOURS=1
SUMMARY_MAX_HOURS=168
ASK_DEFAULT_HOURS=72
ASK_MAX_QUESTION_CHARS=500
EXPORT_DEFAULT_COUNT=20
EXPORT_MIN_COUNT=1
EXPORT_MAX_COUNT=100

# Auto chime
AUTO_CHIME_ENABLED=false
AUTO_CHIME_EVERY_N=10

# Model/API
METIS_BASE_URL=https://api.metisai.ir/api/v1/wrapper/grok
OPENAI_MODEL=grok-4-fast
MODEL_REQUEST_TIMEOUT_SECONDS=300
MODEL_REQUEST_RETRY_COUNT=2

# Memory summarization
MEMORY_SUMMARY_MAX_TOKENS=10000
MEMORY_COMPRESS_PREVIEW_CHARS=200
AUTO_MEMORY_PREVIEW_CHARS=110
AUTO_MEMORY_PREV_SUMMARY_CHARS=3000
AUTO_MEMORY_MAX_TOKENS=2500

# Analyzer limits
ASK_GROUP_USERS_LIMIT=150
ASK_RELEVANT_MESSAGES_LIMIT=24
ASK_RECENT_MESSAGES_LIMIT=14
ASK_FALLBACK_CONTEXT_LIMIT=30
ASK_RESPONSE_MAX_TOKENS=320
ANALYZE_USER_MAX_MESSAGES=200
ANALYZE_USER_RESPONSE_MAX_TOKENS=1500
ASK_USER_MESSAGES_MAX=400
ASK_USER_RESPONSE_MAX_TOKENS=320
